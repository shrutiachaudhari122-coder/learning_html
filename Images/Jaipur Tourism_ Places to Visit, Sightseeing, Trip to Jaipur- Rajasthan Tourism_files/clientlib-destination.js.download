function isAuthor() {
    return window.self !== window.top;
}

'use strict';
$(document).ready(function () {
    fixAnchorInParagraph();
    if (!isAuthor()) {
        setTimeout(function () {
            scrollcolor = $(".active").attr("aria-color"), scrollBar()
        }, 1e3);
    }

    var windowWidth = $(window).width();
    var cityName = getParameterByName();
    if (cityName != 'undefined') {
        var expId = getParameterByNameExp(1);
        setTimeout(function () {
            gotoexplore(cityName, expId);
        }, 200);
        var type;
        if (windowWidth >= 801) {
            type = 3;
        }
        else if (windowWidth < 801) {
            type = 2;
        }
        else if (windowWidth < 481) {
            type = 1;
        }
    }
    if (!isAuthor()) {
        $('#slides').superslides({animation: 'fade'});

        var lang = document.getElementsByTagName('html')[0].getAttribute('lang');
        if(lang=="en"){
        	$(".menu > li").mouseout(function () {
            $(".menu").css("border-bottom", "7px solid #ff8b0f");
            $(".deskLogo").css("background-image", "url(/etc/designs/rajasthan-tourism/clientlib-site/img/header/orange-logo.png)");
        	});
        }else if(lang=="hi"){
	        $(".menu > li").mouseout(function () {
	            $(".menu").css("border-bottom", "7px solid #ff8b0f");
	            $(".deskLogo").css("background-image", "url(/etc/designs/rajasthan-tourism/clientlib-site/img/header/orange-logo-hi.png)");
	        });
	    }
        $('.menu a#navdiscover').addClass('active');
        if (windowWidth >= 481) {
            var elementHeights = $('.articleCont').map(function () {
                return $(this).height();
            }).get();
            var maxHeight = Math.max.apply(null, elementHeights);
            if (maxHeight == 0) {
                maxHeight = 500;
            }
            $('.articleCont').height(maxHeight);
        }
    }
});
function gotoexplore(cityName, expId) {
    if (expId) {
        expId = "#" + expId;
        setTimeout(function () {
            var $tabContainer = $(expId).parent().parent().parent();
            var btnId = "#btn" + $tabContainer.attr("id");
            $(btnId).parent("ul").find("li a").removeClass("active");
            $(".tabContainer").css("display", "none");
            $(btnId).addClass("active");
            $tabContainer.css("display", "block");
            var a = (new Blazy({
                breakpoints: [{width: 420, src: "data-src-small"}], success: function (t) {
                    setTimeout(function () {
                        var a = t.parentNode;
                        a.className = a.className.replace(/\bloading\b/, "")
                    }, 200)
                }
            }), $($tabContainer).attr("id"));

            if ($(expId).offset()) {
                $("html, body").animate({scrollTop: $(expId).offset().top}, 2000);
            }
        }, 1000);
    }
}

function getParameterByName() {
    var pathname = window.location.pathname;
    var res = pathname.split("/");
    var results = "";
    results = res[1];
    return results === null ? "" : decodeURIComponent(results);
}
function getParameterByNameExp(id) {
    var paramCheck = window.location.href.match(/(javascript|src|onerror|%|<|>)/g);
    if(paramCheck != null) return null;
    var hash = window.location.hash.substring(1);
    var results = "";
    results = hash;
    return results === null ? "" : decodeURIComponent(results);
}
function fixAnchorInParagraph(){
    var resultIndx = textWrap = "";
    $(".articleCont p").each(function(index, el){
        textWrap = $(this).text();
        resultIndx = textWrap.indexOf('<a class="dest-know-more-link"');
        if(resultIndx > -1) {
            $(this).text(textWrap.slice(0, resultIndx));
            $(this).append(textWrap.slice(resultIndx));
        }
    });
}
﻿﻿function facbookshare() {
