$(".menu a[aria-img='orange-logo.png']").addClass('active');

function twitershare() {
    var t = $("#txtTwiter").val();
    t = t.replace("#", "%23"), t = t.replace("&", "%26");
    var a = $("#txtShareUrl").val();
    return newwindow = window.open("https://twitter.com/share?text=" + t + "&url=" + a, "name", "toolbar=no, location=no, directories=no, status=no, menubar=no, scrollbars=no, resizable=no, copyhistory=no, width=600, height=400, top=200, left=300"), window.focus && newwindow.focus(), !1
}
$(document).ready(function () {
    $(".tabContainer").css("display", "none");
    var paramCheck = window.location.href.match(/(javascript|src|onerror|%|<|>)/g);
    if(paramCheck != null) return null;
    var t = window.location.hash.substr(1);
    if (!t) {
        ($("#btnSee").addClass("active"), $("#See").css("display", "block"));
    }
    $("#exploretab > li > a").click(function (t) {
        var a = (new Blazy({
            breakpoints: [{width: 420, src: "data-src-small"}], success: function (t) {
                setTimeout(function () {
                    var a = t.parentNode;
                    a.className = a.className.replace(/\bloading\b/, "")
                }, 200)
            }
        }), $(this).attr("id"));
        $(".tabContainer").css("display", "none"), $("#" + a.replace("btn", "")).css("display", "block"), $("#exploretab > li > a").removeClass("active"), $(this).addClass("active"), t.preventDefault()
    })
});
