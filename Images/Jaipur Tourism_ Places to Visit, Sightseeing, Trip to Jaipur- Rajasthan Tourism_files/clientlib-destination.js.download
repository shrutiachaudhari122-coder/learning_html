        i = a, n = e, o = t, r = " ", c = s, l = [{name: o, link: c}];
    FB.ui({
        method: "feed",
        name: o,
        link: c,
        picture: n,
        caption: " ",
        description: i,
        message: r,
        actions: l
    }, function (t) {
    })
}
